{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Fortran",
            "group": "build",
            "dependsOn": ["make build dir", "compile"],
            "dependsOrder": "sequence",
            "presentation": {
                "echo": false,
                "reveal": "silent",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "make build dir",
            "type": "shell",
            "windows": {
                "command": "cmd",
                "args": ["/C", "if not exist .\\build mkdir .\\build"]
            },
            "presentation": {
                "echo": false,
                "reveal": "silent",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "compile",
            "type": "shell",
            "command": "gfortran",
            "args": [
                "-g",
                "${file}",
                "-o",
                "./build/${fileBasenameNoExtension}.exe"
            ],
            "presentation": {
                "echo": false,
                "reveal": "silent",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "Remove Python Dist Folder",
            "type": "shell",
            "command": "cmd",
            "args": ["/C", "if exist .\\dist rmdir /S /Q .\\build"]
        },
        {
            "label": "Build Python Package",
            "type": "shell",
            "command": "python",
            "args": ["setup.py", "sdist", "bdist_wheel"]
        },
        {
            "label": "Check Python Package",
            "type": "shell",
            "command": "twine",
            "args": ["check", "dist/*"]
        },
        {
            "label": "Publish Python Package",
            "type": "shell",
            "command": "twine",
            "args": ["upload", "dist/*"]
        },
        {
            "label": "Build/Publish Python Package",
            "group": "build",
            "dependsOn": [
                "Remove Python Dist Folder",
                "Build Python Package",
                "Check Python Package",
                "Publish Python Package"
            ],
            "dependsOrder": "sequence"
        }
    ]
}
